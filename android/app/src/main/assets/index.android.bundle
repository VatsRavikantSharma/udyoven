e:'4',delta:'+1',positive:!1,tone:'warning'},{label:'Avg Lead Time',value:'5.2d',delta:'\u22120.4d',positive:!0,tone:'info'}],inventory:[{label:'Total SKUs',value:'142',delta:'+3',positive:!0,tone:'primary'},{label:'Low Stock Items',value:'9',delta:'+2',positive:!1,tone:'warning'},{label:'Stock Value',value:'\u20b948.2L',delta:'+\u20b91.8L',positive:!0,tone:'accent'},{label:'Dead Stock',value:'\u20b92.4L',delta:'\u2212\u20b90.2L',positive:!0,tone:'info'}],qc:[{label:'Inspections',value:'24',delta:'+4',positive:!0,tone:'primary'},{label:'Rejection Rate',value:'1.7%',delta:'+0.3%',positive:!1,tone:'danger'},{label:'Rework Items',value:'12',delta:'\u22123',positive:!0,tone:'warning'},{label:'First-Pass Yield',value:'94.8%',delta:'+0.8%',positive:!0,tone:'accent'}],dispatch:[{label:'Dispatched Today',value:'6',delta:'+1',positive:!0,tone:'accent'},{label:'In Transit',value:'11',delta:'+2',positive:!0,tone:'primary'},{label:'Delayed',value:'3',delta:'+1',positive:!1,tone:'danger'},{label:'Delivered',value:'28',delta:'+6',positive:!0,tone:'info'}],financial:[{label:'Revenue',value:'\u20b984.6L',delta:'+12%',positive:!0,tone:'accent'},{label:'Receivables',value:'\u20b936.4L',delta:'+\u20b94.2L',positive:!1,tone:'danger'},{label:'Collections',value:'\u20b924.0L',delta:'+\u20b93.2L',positive:!0,tone:'primary'},{label:'Overdue',value:'\u20b918.4L',delta:'+\u20b92.1L',positive:!1,tone:'warning'}],vendor:[{label:'Active Vendors',value:'12',delta:'0',positive:!0,tone:'primary'},{label:'Avg Reliability',value:'88%',delta:'\u22121%',positive:!1,tone:'warning'},{label:'Delayed Supplies',value:'3',delta:'+1',positive:!1,tone:'danger'},{label:'Avg Lead Time',value:'5.6d',delta:'+0.4d',positive:!1,tone:'info'}],machine:[{label:'Machine Uptime',value:'96%',delta:'+1%',positive:!0,tone:'accent'},{label:'OEE',value:'78%',delta:'\u22122%',positive:!1,tone:'warning'},{label:'Alerts Today',value:'3',delta:'+1',positive:!1,tone:'danger'},{label:'MTBF',value:'184h',delta:'+12h',positive:!0,tone:'primary'}]},c={production:{insight:'Production efficiency improved by 2.1% this week, driven by Line A performance gains after shift rescheduling.',trend:'Weekly output has grown steadily over 7 days \u2014 up 18% from last Monday. Weekend shift utilization is improving.',variance:'\u26a0 Batch B19 shows 38% deviation from target output \u2014 sand casting delay is the primary driver.',forecast:'If current pace holds, projected monthly output will exceed target by ~4% (est. 26,400 units vs. 25,400 target).'},fulfillment:{insight:'Order fulfillment rate at 92% \u2014 3-point improvement vs. last week. Top risk: 2 orders tied to Batch B19 hold.',trend:'On-time delivery has improved every week for the past 4 weeks. Average lead time dropped 0.4 days.',forecast:'At current fulfillment rate, month-end target of 95% is achievable if Batch B19 hold is resolved by 25 Apr.'},inventory:{insight:'Steel Coil 4mm and Brass Rod 12mm are in critical low-stock state. Combined procurement exposure: \u20b92.6L.',trend:'Inventory value grew \u20b91.8L this week on FG stock build-up. Raw material value declined due to consumption.',variance:'\u26a0 Aluminium Sheet 6mm is 213% over-stocked. Recommend pausing next procurement order.',forecast:'At current consumption rate, Steel Coil 4mm will be exhausted in ~2.8 days. Expedite PO-1051.'},qc:{insight:'First-pass yield improved to 94.8%. Batch B17 remains the primary drag \u2014 6.2% rejection from surface finish issue.',trend:'Rejection rates have been declining over the past 3 weeks. Batch B20 performed best this period.',variance:'\u26a0 Batch B17 rejection (6.2%) is 2x the weekly average. Inspector M. Joshi flagged tooling wear as root cause.',forecast:'If B17 tooling is replaced, projected rejection rate for next batch: ~2.1% (within 3% threshold).'},dispatch:{insight:'6 dispatches completed today. 3 delays tracked \u2014 primary cause: packaging delay and transporter no-show.',trend:'Dispatch volumes trending upward \u2014 up 8 dispatches vs. last week. In-transit count at seasonal high.',forecast:'If current dispatch pace continues, monthly dispatch target will be met 2 days ahead of schedule.'},financial:{insight:'Revenue is up 12% week-over-week. However, outstanding receivables of \u20b936.4L require immediate follow-up.',trend:'Collections are improving \u2014 \u20b924L collected this week vs. \u20b918L last week. Tata Forge overdue is the key risk.',variance:'\u26a0 Receivables grew faster than revenue this period (+16% vs. +12%). Working capital pressure increasing.',forecast:'If \u20b918.4L overdue is collected this week, projected cash position improves by 26% by month-end.'},vendor:{insight:'Average vendor reliability at 88% \u2014 slightly down from 89% last week. Bombay Metals delay is primary driver.',trend:'Jindal Steel and SKF India maintain top reliability (92%, 96%). Pune Castings Co. trending downward.',variance:'\u26a0 Bombay Metals reliability dropped 6 points in 2 weeks. Consider qualifying alternate supplier.',forecast:'Projected vendor spend for May: \u20b942L \u2014 up 8% due to accelerated raw material procurement.'},machine:{insight:'Machine uptime at 96% \u2014 strong performance. CNC-03 overheat alert is the critical open item.',trend:'OEE declined 2% this week due to CNC-03 downtime. All other machines performing within targets.',variance:'\u26a0 CNC-03 MTBF has dropped from 220h to 184h over the past 3 maintenance cycles.',forecast:'Scheduled maintenance for VMC-01 (overdue 2 days) could reduce uptime by 3-4% next week if not addressed.'}},p={production:[{metric:'Units Produced',current:'6,012',prev:'5,544',change:'+8.4%',positive:!0},{metric:'Efficiency',current:'86%',prev:'83.9%',change:'+2.1%',positive:!0},{metric:'Rejection Rate',current:'1.7%',prev:'1.4%',change:'+0.3%',positive:!1},{metric:'Downtime Hours',current:'4.2h',prev:'3.1h',change:'+1.1h',positive:!1}],fulfillment:[{metric:'Orders Fulfilled',current:'38',prev:'33',change:'+15.1%',positive:!0},{metric:'On-Time Rate',current:'92%',prev:'89%',change:'+3%',positive:!0},{metric:'Delayed Orders',current:'4',prev:'3',change:'+1',positive:!1},{metric:'Avg Lead Time',current:'5.2d',prev:'5.6d',change:'\u22120.4d',positive:!0}],inventory:[{metric:'Stock Value',current:'\u20b948.2L',prev:'\u20b946.4L',change:'+\u20b91.8L',positive:!0},{metric:'Low Stock Items',current:'9',prev:'7',change:'+2',positive:!1},{metric:'Stockouts',current:'1',prev:'0',change:'+1',positive:!1},{metric:'Inventory Turns',current:'4.2x',prev:'3.9x',change:'+0.3x',positive:!0}],qc:[{metric:'Inspections Done',current:'24',prev:'20',change:'+20%',positive:!0},{metric:'Rejection Rate',current:'1.7%',prev:'2.1%',change:'\u22120.4%',positive:!0},{metric:'First-Pass Yield',current:'94.8%',prev:'94.0%',change:'+0.8%',positive:!0},{metric:'Rework Cost',current:'\u20b922K',prev:'\u20b918K',change:'+\u20b94K',positive:!1}],dispatch:[{metric:'Total Dispatches',current:'6',prev:'5',change:'+20%',positive:!0},{metric:'Delay Rate',current:'33%',prev:'20%',change:'+13%',positive:!1},{metric:'Avg Transit Days',current:'2.8d',prev:'2.4d',change:'+0.4d',positive:!1},{metric:'Delivery Accuracy',current:'97%',prev:'98%',change:'\u22121%',positive:!1}],financial:[{metric:'Revenue',current:'\u20b984.6L',prev:'\u20b975.5L',change:'+12%',positive:!0},{metric:'Collections',current:'\u20b924.0L',prev:'\u20b918.8L',change:'+27%',positive:!0},{metric:'Receivables',current:'\u20b936.4L',prev:'\u20b931.2L',change:'+16%',positive:!1},{metric:'Overdue Amount',current:'\u20b918.4L',prev:'\u20b916.3L',change:'+13%',positive:!1}],vendor:[{metric:'Avg Reliability',current:'88%',prev:'89%',change:'\u22121%',positive:!1},{metric:'Delayed Supplies',current:'3',prev:'2',change:'+1',positive:!1},{metric:'Vendor Spend',current:'\u20b938.9L',prev:'\u20b936.0L',change:'+8%',positive:!1},{metric:'Avg Lead Time',current:'5.6d',prev:'5.2d',change:'+0.4d',positive:!1}],machine:[{metric:'Uptime',current:'96%',prev:'97%',change:'\u22121%',posit